                "200": {
                  "description": "List of all users"
                }
              }
            }
          },
          "/api/v1/users/{id}": {
            "delete": {
              "summary": "Delete a user",
              "parameters": [
                {
                  "name": "id",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "User deleted successfully"
                }
              }
            }
          }
        }
      }
